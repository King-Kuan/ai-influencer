# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# DEEPSEEK_API_KEY: Optional if using DeepSeek instead of Gemini
DEEPSEEK_API_KEY=

# CF_WORKER_URL: URL for Cloudflare Workers AI image generation
CF_WORKER_URL=

# R2_ACCOUNT_ID: Cloudflare R2 Account ID
R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID: Cloudflare R2 Access Key
R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY: Cloudflare R2 Secret Key
R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME: Cloudflare R2 Bucket Name
R2_BUCKET_NAME=

# INSTAGRAM_BUSINESS_ID: Instagram Business Account ID
INSTAGRAM_BUSINESS_ID=
# INSTAGRAM_ACCESS_TOKEN: Instagram Graph API Access Token
INSTAGRAM_ACCESS_TOKEN=

# CRON_SECRET: Secret for protecting the cron endpoint
CRON_SECRET=
