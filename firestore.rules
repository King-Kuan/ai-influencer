rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /campaigns/{campaignId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }
    match /scheduled_posts/{postId} {
      // Backend handles most of this, but for frontend visibility:
      allow read: if request.auth != null; // Ideally filter by campaignId ownership but cross-collection checks are complex
      allow write: if false; // Only server (firebase-admin) writes to scheduled_posts
    }
  }
}
